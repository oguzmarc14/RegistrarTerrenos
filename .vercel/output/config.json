{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/editarTerreno-api/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/registrarTerreno-api/?$",
			"dest": "_render"
		},
		{
			"src": "^/EditarTerreno/?$",
			"dest": "_render"
		},
		{
			"src": "^/EditarTerrenoId/?$",
			"dest": "_render"
		},
		{
			"src": "^/iniciarsesion/?$",
			"dest": "_render"
		},
		{
			"src": "^/MapaTerrenos/?$",
			"dest": "_render"
		},
		{
			"src": "^/panelAdmin/?$",
			"dest": "_render"
		},
		{
			"src": "^/primeroIniciarSesion/?$",
			"dest": "_render"
		},
		{
			"src": "^/RegistrarTerrenos/?$",
			"dest": "_render"
		},
		{
			"src": "^/Terreno/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/Terrenos/?$",
			"dest": "_render"
		},
		{
			"src": "^/TipoTerreno/Casas/?$",
			"dest": "_render"
		},
		{
			"src": "^/TipoTerreno/Departamentos/?$",
			"dest": "_render"
		},
		{
			"src": "^/TipoTerreno/PropiedadesComerciales/?$",
			"dest": "_render"
		},
		{
			"src": "^/TipoTerreno/Terrenos/?$",
			"dest": "_render"
		},
		{
			"src": "^/TipoTerreno/TerrenosComerciales/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}