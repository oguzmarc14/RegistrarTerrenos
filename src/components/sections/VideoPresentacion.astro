<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const video = document.getElementById("video-presentacion");
    const playPauseBtn = document.getElementById("playPauseBtn");
    const muteBtn = document.getElementById("muteBtn");
    const restartBtn = document.getElementById("restartBtn");

    if (!video || !playPauseBtn || !muteBtn || !restartBtn) return;

    playPauseBtn.addEventListener("click", () => {
      if (video.paused) {
        video.play();
        playPauseBtn.textContent = "⏸";
        playPauseBtn.setAttribute("aria-label", "Pausar video");
      } else {
        video.pause();
        playPauseBtn.textContent = "▶";
        playPauseBtn.setAttribute("aria-label", "Reproducir video");
      }
    });

    muteBtn.addEventListener("click", () => {
      video.muted = !video.muted;
      muteBtn.textContent = video.muted ? "🔇" : "🔊";
      muteBtn.setAttribute(
        "aria-label",
        video.muted ? "Activar sonido" : "Silenciar video"
      );
    });

    restartBtn.addEventListener("click", () => {
      video.currentTime = 0;
      video.play();
      playPauseBtn.textContent = "⏸";
      playPauseBtn.setAttribute("aria-label", "Pausar video");
    });
  });
</script>

