  ---
  interface Props {
    id: string | number;
    titulo: string;
    descripcion: string;
    precio: number;
    imagenes: string[];
    textBoton: string;
    hrefBoton: string; // ya no lo usaremos, pero lo dejo por compat
    medidas?: string;
    ubicacion?: string;
    fecha?: string;
  }

  const {
    id,
    titulo,
    descripcion,
    precio,
    imagenes = [],
    medidas,
    ubicacion,
    fecha,
    textBoton,
  } = Astro.props;

  // Si quieres usar los web components de Swiper empacados por Vite:
  import 'swiper/element/bundle';
  ---

  <article class="relative flex h-160 flex-col overflow-hidden rounded-[1.6rem] border border-slate-200/70 bg-white/95 shadow-[0_20px_50px_rgba(15,23,42,0.12)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_28px_70px_rgba(15,23,42,0.18)]">
    <!-- Carrusel -->
    <swiper-container
      class="w-full h-70 rounded-t-[1.6rem]"
      slides-per-view="1"
      pagination="true"
      navigation="true"
      loop={imagenes.length > 1 ? 'true' : 'false'}
    >
      {imagenes.length > 0 ? (
        imagenes.map((img, i) => (
          <swiper-slide>
            <img
              src={img}
              alt={`${titulo} imagen ${i + 1}`}
              class="w-full h-70 object-cover"
              loading="lazy"
            />
          </swiper-slide>
        ))
      ) : (
        <swiper-slide>
          <img
            src="/no-image.jpg"
            alt="Sin imagen"
            class="w-full h-70 object-cover"
            loading="lazy"
          />
        </swiper-slide>
      )}
    </swiper-container>

    <!-- Contenido -->
    <div class="flex flex-1 flex-col p-5 sm:p-6">
      <div class="space-y-2">
        <h2 class="text-[1.35rem] font-semibold tracking-tight text-slate-950">{titulo}</h2>
        <p class="text-sm leading-6 text-slate-600 overflow-hidden" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;">{descripcion}</p>
        <div class="flex items-center justify-between gap-3 pt-1">
          <p class="text-lg font-bold text-emerald-700">${Number(precio).toLocaleString()} MXN</p>
        </div>
        <div class="space-y-1 text-sm text-slate-500">
          {medidas && <p>Medidas: {medidas}</p>}
          {ubicacion && <p>Ubicación: {ubicacion}</p>}
        </div>
      </div>

      <div class="mt-auto mb-3 flex flex-wrap gap-3 pt-4">
        <!-- Botón WhatsApp -->
        <a
          href={`https://wa.me/524759513349?text=${
            encodeURIComponent(
              `Hola, quiero información de este terreno: ${titulo}${ubicacion ? ` en ${ubicacion}` : ''}`
            )
          }`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-w-[150px] flex-1 items-center justify-center gap-2 rounded-full border border-emerald-700/20 bg-gradient-to-r from-emerald-600 to-emerald-500 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-950/15 transition hover:-translate-y-0.5 hover:from-emerald-500 hover:to-emerald-400"
        >
          {textBoton}
        </a>

        <a
          href={`/Terreno/${id}`}
          class="inline-flex min-w-[150px] flex-1 items-center justify-center gap-2 rounded-full border border-blue-950/20 bg-gradient-to-r from-blue-950 via-slate-900 to-blue-900 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-950/20 transition hover:-translate-y-0.5 hover:from-blue-900 hover:via-slate-900 hover:to-blue-800"
        >
          Ver más
        </a>
      </div>
    </div>
  </article>


  <!-- ✅ Import Swiper Web Components -->
  <script type="module">
    import "swiper/element/bundle";
  </script>
