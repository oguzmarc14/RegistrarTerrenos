---
const { terreno } = Astro.props;

const imagenes: string[] = Array.isArray(terreno.imagenes) ? terreno.imagenes : [];
---

<form
  id="formularioEditarTerreno"
  class="mx-auto max-w-5xl rounded-[2rem] border border-white/10 bg-white/10 p-5 shadow-2xl shadow-black/30 backdrop-blur-md sm:p-8 lg:p-10"
>
  <input type="hidden" name="id" value={terreno.id} />

  <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="rounded-[1.5rem] border border-white/10 bg-sky-950/40 p-5 sm:p-6">
      <h2 class="mb-5 text-xl font-bold text-white">
        Información del terreno
      </h2>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <input
          name="titulo"
          value={terreno.titulo || ""}
          placeholder="Nombre del terreno"
          required
          class="md:col-span-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-white outline-none placeholder:text-white/50 focus:border-amber-400"
        />

        <textarea
          name="descripcion"
          placeholder="Descripción"
          required
          class="md:col-span-2 h-40 resize-y rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-white outline-none placeholder:text-white/50 focus:border-amber-400"
        >{terreno.descripcion || ""}</textarea>

        <input
          name="precio"
          type="text"
          value={terreno.precio || ""}
          placeholder="Precio ej. 50000, Consultar, A negociar"
          required
          class="rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-white outline-none placeholder:text-white/50 focus:border-amber-400"
        />

        <input
          name="medidas"
          value={terreno.medidas || ""}
          placeholder="Medidas Ej. 120x60"
          class="rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-white outline-none placeholder:text-white/50 focus:border-amber-400"
        />

        <input
          name="ubicacion"
          value={terreno.ubicacion || ""}
          placeholder="Ubicación"
          class="md:col-span-2 rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-white outline-none placeholder:text-white/50 focus:border-amber-400"
        />

        <input
          name="googleMaps"
          value={terreno.google_maps || ""}
          placeholder="Link de Google Maps"
          class="md:col-span-2 rounded-2xl border border-cyan-400/20 bg-cyan-400/5 px-4 py-3 text-white outline-none placeholder:text-cyan-100/50 focus:border-cyan-400"
        />

        <select
          name="tipo"
          required
          class="md:col-span-2 rounded-2xl border border-white/15 bg-sky-950/80 px-4 py-3 text-white outline-none focus:border-amber-400"
        >
          <option value="">Selecciona el tipo de propiedad</option>
          <option value="terreno" selected={terreno.tipo === "terreno"}>Terreno</option>
          <option value="casa" selected={terreno.tipo === "casa"}>Casa</option>
          <option value="comercial" selected={terreno.tipo === "comercial"}>Propiedad Comercial</option>
          <option value="departamento" selected={terreno.tipo === "departamento"}>Departamento</option>
          <option value="terreno-comercial" selected={terreno.tipo === "terreno-comercial"}>Terreno Comercial</option>
        </select>
      </div>
    </div>

    <div class="rounded-[1.5rem] border border-white/10 bg-white/80 p-5 text-sky-900 shadow-xl sm:p-6">
      <h2 class="text-xl font-bold">
        Imágenes del terreno
      </h2>

      <p class="mt-2 text-sm leading-6 text-sky-950">
        Da clic sobre una imagen para elegirla como portada principal.
      </p>

      <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-4">
        <h3 class="mb-3 text-sm font-bold uppercase tracking-[0.18em] text-sky-800">
          Imágenes actuales
        </h3>

        <div
          id="imagenes-actuales"
          class="grid max-h-72 grid-cols-2 gap-3 overflow-y-auto pr-1 sm:grid-cols-3 lg:grid-cols-4"
        >
          {
            imagenes.map((img, index) => (
              <button
                type="button"
                class="imagen-actual group relative overflow-hidden rounded-2xl text-left transition hover:scale-[1.03]"
                data-url={img}
              >
                <img
                  src={img}
                  alt={`Imagen ${index + 1}`}
                  class={index === 0
                    ? "h-32 w-full rounded-2xl border-4 border-sky-500 object-cover shadow-2xl"
                    : "h-24 w-full rounded-2xl border border-slate-200 object-cover shadow-md opacity-80 group-hover:opacity-100"}
                />

                <span class={index === 0
                  ? "badge-portada absolute left-2 top-2 rounded-full bg-sky-600 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-white shadow-lg backdrop-blur"
                  : "badge-portada absolute left-2 top-2 rounded-full bg-black/60 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-white opacity-0 shadow-lg backdrop-blur transition group-hover:opacity-100"}
                >
                  {index === 0 ? "Portada" : "Elegir portada"}
                </span>
              </button>
            ))
          }
        </div>
      </div>

      <div class="mt-6 flex justify-center">
        <div class="flex min-h-44 w-full flex-col items-center justify-center rounded-3xl border-2 border-dashed border-sky-900/20 bg-slate-50 p-6 text-center transition hover:border-sky-800 hover:bg-sky-50">
          <input
            type="file"
            id="nuevasImagenes"
            name="nuevasImagenes"
            accept="image/*"
            multiple
            class="hidden"
          />

          <label
            for="nuevasImagenes"
            class="cursor-pointer rounded-2xl bg-sky-900 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-950/20 transition hover:bg-sky-800"
          >
            Agregar nuevas imágenes
          </label>

          <p class="mt-3 text-xs text-slate-500">
            Puedes elegir una nueva imagen como portada.
          </p>
        </div>
      </div>

      <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-4">
        <h3 class="mb-3 text-sm font-bold uppercase tracking-[0.18em] text-sky-800">
          Nuevas imágenes
        </h3>

        <div
          id="previewNuevas"
          class="grid max-h-72 grid-cols-2 gap-3 overflow-y-auto pr-1 sm:grid-cols-3 lg:grid-cols-4"
        ></div>
      </div>
    </div>
  </div>

  <div class="mt-8 flex justify-center">
    <button
      type="submit"
      id="botonEditarTerrenoId"
      class="rounded-2xl bg-emerald-700 px-8 py-3.5 text-sm font-bold text-white shadow-lg shadow-emerald-950/20 transition hover:bg-emerald-600"
    >
      Guardar cambios
    </button>
  </div>
</form>

<script type="module" src="/ts/EditarTerrenoForm.js"></script>