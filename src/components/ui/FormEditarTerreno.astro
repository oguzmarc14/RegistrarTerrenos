---
// Formulario para editar un terreno individual
const { terreno } = Astro.props;
const imagenesActuales = Array.isArray(terreno.imagenes) ? (terreno.imagenes as string[]) : [];
---
<form id="formularioEditarTerreno" class="mx-auto mt-8 w-full max-w-6xl overflow-hidden rounded-[2rem] border border-white/10 bg-white shadow-2xl shadow-black/20 text-slate-900">
  <div class="grid lg:grid-cols-[1.05fr_0.95fr]">
    <div class="bg-gradient-to-br from-sky-950 via-sky-900 to-sky-800 p-6 text-white sm:p-8 lg:p-10">
      <div class="mb-6">
        <span class="inline-flex rounded-full bg-white/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.25em] text-white/80">
          Edición de propiedad
        </span>
        <h2 class="mt-4 text-2xl font-bold tracking-tight sm:text-3xl">
          Ajusta los datos del terreno
        </h2>
        <p class="mt-3 max-w-xl text-sm leading-7 text-sky-100/80 sm:text-base">
          Mantén una presentación más limpia mientras editas título, descripción, tipo, imágenes y ubicación.
        </p>
      </div>

      <div class="space-y-4 text-sm text-sky-100/85">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/60">ID</p>
          <p class="mt-1 font-semibold">{terreno.id}</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/60">Imágenes actuales</p>
          <div id="imagenes-actuales" class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-3 xl:grid-cols-4">
            {imagenesActuales.map((img, idx) => (
              <div class="overflow-hidden rounded-2xl ring-1 ring-white/10">
                <img src={img} alt={`img${idx}`} class="h-24 w-full object-cover sm:h-28" />
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="p-6 sm:p-8 lg:p-10">
      <div class="grid gap-4">
        <input type="hidden" name="id" value={terreno.id} />
        <div class="grid gap-4 md:grid-cols-2">
          <input name="titulo" value={terreno.titulo ?? ''} placeholder="Nombre del terreno" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 p-4 text-slate-900 placeholder-slate-400 outline-none transition focus:border-sky-900/40 focus:bg-white" />
          <input name="precio" value={terreno.precio ?? ''} placeholder="Precio" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 p-4 text-slate-900 placeholder-slate-400 outline-none transition focus:border-sky-900/40 focus:bg-white" />
        </div>

        <textarea name="descripcion" maxlength="320" placeholder="Descripción" required class="h-40 resize-none rounded-2xl border border-slate-200 bg-slate-50 p-4 text-slate-900 placeholder-slate-400 outline-none transition focus:border-sky-900/40 focus:bg-white">{terreno.descripcion ?? ''}</textarea>
        <p class="-mt-2 text-xs text-slate-500">Máximo 47 palabras.</p>

        <div class="grid gap-4 md:grid-cols-2">
          <input name="medidas" value={terreno.medidas ?? ''} placeholder="Medidas (Ej. 120x60)" class="w-full rounded-2xl border border-slate-200 bg-slate-50 p-4 text-slate-900 placeholder-slate-400 outline-none transition focus:border-sky-900/40 focus:bg-white" />
          <input name="ubicacion" value={terreno.ubicacion ?? ''} placeholder="Ubicación" class="w-full rounded-2xl border border-slate-200 bg-slate-50 p-4 text-slate-900 placeholder-slate-400 outline-none transition focus:border-sky-900/40 focus:bg-white" />
        </div>

        <select name="tipo" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 p-4 text-slate-900 outline-none transition focus:border-sky-900/40 focus:bg-white">
          <option value="">Selecciona el tipo de propiedad</option>
          <option value="terreno" selected={terreno.tipo === 'terreno'}>Terreno</option>
          <option value="casa" selected={terreno.tipo === 'casa'}>Casa</option>
          <option value="comercial" selected={terreno.tipo === 'comercial'}>Propiedad Comercial</option>
          <option value="departamento" selected={terreno.tipo === 'departamento'}>Departamento</option>
          <option value="terreno-comercial" selected={terreno.tipo === 'terreno-comercial'}>Terreno Comercial</option>
        </select>

        <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4">
          <label class="block text-sm font-semibold text-slate-700">Agregar nuevas imágenes</label>
          <input type="file" id="nuevasImagenes" name="imagenes" accept="image/*" multiple class="mt-3 block w-full text-sm text-slate-600 file:mr-4 file:rounded-full file:border-0 file:bg-sky-900 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:bg-sky-800" />
          <div id="previewNuevas" class="mt-4 flex flex-wrap gap-3"></div>
        </div>

        <div class="flex flex-col gap-3 pt-2 sm:flex-row">
          <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-sky-900 px-6 py-3 font-semibold text-white shadow-lg shadow-sky-950/20 transition hover:bg-sky-800">Guardar cambios</button>
        </div>
      </div>
    </div>
  </div>
</form>
<script type="module" src="/ts/EditarTerrenoForm.js"></script>
